---
import Base from '../layouts/Base.astro';

const showcase = `# A tiny pricing model in Tyra: algebraic data types, exhaustive
# matching, errors as values (Result), and no null anywhere.
type Plan =
  | Free
  | Pro(seats: Int)
  | Enterprise(seats: Int, discount: Int)

fn monthly_cost(plan: Plan) -> Result<Int, String>
  match plan
  when Free
    Ok(0)

  when Pro(seats)
    Ok(seats * 20)

  when Enterprise(seats, discount)
    if discount < 0 or discount > 100
      Err("discount #{discount}% is out of range")
    else
      Ok(((seats * 15) * (100 - discount)) / 100)
    end
  end
end

fn main() -> Unit
  let plans = [Plan.Free, Plan.Pro(seats: 5), Plan.Enterprise(seats: 50, discount: 20)]
  for plan in plans
    match monthly_cost(plan)
    when Ok(cost)
      println("$#{cost}/mo")

    when Err(msg)
      println("error: #{msg}")
    end
  end
end
`;
---
<Base title="Home" description="Tyra is a readable, statically-typed, Ruby-flavored compiled language — Ruby-like syntax, LLVM-native binaries, no null, Result/Option, and exhaustive pattern matching.">
  <style>
    .hero {
      text-align: center;
      padding: 4rem 0 3rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 3rem;
    }

    .hero-logo {
      font-size: 4rem;
      font-weight: 800;
      color: var(--accent);
      letter-spacing: -0.04em;
      margin-bottom: 0.5rem;
    }

    .hero-tagline {
      font-size: 1.5rem;
      color: var(--text);
      font-weight: 500;
      margin-bottom: 1rem;
    }

    .hero-sub {
      font-size: 1.05rem;
      color: var(--text-muted);
      max-width: 580px;
      margin: 0 auto 2rem;
      line-height: 1.7;
    }

    .hero-sub strong {
      color: var(--accent);
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .install {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--code-bg, #161b22);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.5rem 0.75rem;
      margin: 0 auto 1.5rem;
      max-width: 100%;
      overflow-x: auto;
      font-size: 0.85rem;
    }

    .install code {
      font-family: var(--mono, ui-monospace, SFMono-Regular, Menlo, monospace);
      color: var(--text);
      white-space: nowrap;
    }

    .copy-btn {
      flex-shrink: 0;
      background: var(--accent);
      color: #0d1117;
      border: none;
      border-radius: 4px;
      padding: 0.2rem 0.6rem;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
    }

    .copy-btn:hover { opacity: 0.9; }

    .section {
      margin-bottom: 3.5rem;
    }

    .section-title {
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      align-items: start;
    }

    @media (max-width: 700px) {
      .two-col { grid-template-columns: 1fr; }
    }

    .highlight-row td:first-child {
      font-weight: 700;
      color: var(--accent);
    }

    .badge-tyra {
      background: var(--accent);
      color: #0d1117;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.1rem 0.4rem;
      border-radius: 4px;
      margin-left: 0.4rem;
      vertical-align: middle;
    }

    .leaderboard-note {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
    }

    .view-more {
      display: inline-block;
      margin-top: 0.75rem;
      font-size: 0.9rem;
      font-weight: 500;
    }
  </style>

  <div class="hero">
    <div class="hero-logo">Tyra</div>
    <div class="hero-tagline">A readable, statically-typed, Ruby-flavored compiled language</div>
    <p class="hero-sub">
      Tyra reads like Ruby, compiles to native binaries via LLVM, and ships with no null,
      exhaustive pattern matching, and <code>Result</code>/<code>Option</code> built in.
      Its design also makes code unusually predictable — given only the spec and no prior
      training data, Claude writes correct Tyra on the first try
      <strong>88.7% of the time</strong> (<a href="/leaderboard/">3 seeds &times; 100 tasks — methodology</a>).
    </p>
    <div class="install">
      <code id="install-cmd">curl -fsSL https://raw.githubusercontent.com/tyra-lang/tyra/main/scripts/install.sh | sh</code>
      <button class="copy-btn" data-clipboard="#install-cmd" aria-label="Copy install command" type="button">Copy</button>
    </div>
    <div class="hero-actions">
      <a href="/playground/?sample=showcase&amp;run=1" class="btn btn-primary">Run it in your browser &rarr;</a>
      <a href="https://github.com/tyra-lang/tyra" class="btn btn-secondary" target="_blank" rel="noopener">&#9733; Star on GitHub</a>
    </div>
  </div>

  <div class="two-col">
    <div class="section">
      <div class="section-title">Code preview</div>
      <pre><code>{showcase}</code></pre>
      <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 0.5rem;">
        Algebraic data types, exhaustive matching, <code>Result</code> instead of exceptions, no null.
        <a href="/playground/?sample=showcase&amp;run=1">Run it live &rarr;</a>
      </p>
    </div>

    <div class="section">
      <div class="section-title">LLM pass rate benchmark</div>
      <table>
        <thead>
          <tr>
            <th>Language</th>
            <th>Pass rate</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Ruby</td>
            <td>99.0%</td>
          </tr>
          <tr>
            <td>Crystal</td>
            <td>96.0%</td>
          </tr>
          <tr class="highlight-row">
            <td>
              Tyra + spec
              <span class="badge-tyra">NEW</span>
            </td>
            <td><strong>88.7%</strong></td>
          </tr>
          <tr>
            <td>Go</td>
            <td>81.0%</td>
          </tr>
          <tr>
            <td>V</td>
            <td>49.0%</td>
          </tr>
          <tr>
            <td>Gleam</td>
            <td>37.0%</td>
          </tr>
        </tbody>
      </table>
      <p class="leaderboard-note">
        Tyra's 88.7% is a 3-seed mean with the spec injected as a system prompt. The other
        languages are single-seed point estimates from a separate run — directional context only,
        not a same-condition comparison (a multi-seed cross-language sweep is pending).
      </p>
      <a href="/leaderboard" class="view-more">View full leaderboard &rarr;</a>
    </div>
  </div>

  <div class="section">
    <div class="section-title">Design goals</div>
    <div class="two-col">
      <div>
        <h3>Readable by humans, predictable for tools</h3>
        <p style="color: var(--text-muted);">
          <code>end</code> blocks, explicit argument labels, no implicit conversions, one way to do things.
          The same design that makes Tyra easy to read also lets an LLM generate correct code from the
          spec alone — the 88.7% result uses zero training data on Tyra, only the spec.
        </p>
      </div>
      <div>
        <h3>Type system that catches real bugs</h3>
        <p style="color: var(--text-muted);">
          No <code>==</code> on <code>Float</code>, no <code>Map&lt;Float, V&gt;</code>,
          no null. The compiler rejects entire classes of bugs before they reach the test runner.
          <a href="https://dev.to/tyra-lang/why-float-has-no-eq" target="_blank" rel="noopener">Why Float has no == &rarr;</a>
        </p>
      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const sel = btn.getAttribute('data-clipboard');
        const el = sel ? document.querySelector(sel) : null;
        if (!el || !el.textContent) return;
        const text = el.textContent.trim();
        const flash = (label) => {
          const prev = btn.textContent;
          btn.textContent = label;
          setTimeout(() => { btn.textContent = prev; }, 1500);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text)
            .then(() => flash('Copied!'))
            .catch(() => flash('Press ⌘/Ctrl+C'));
        } else {
          flash('Press ⌘/Ctrl+C');
        }
      });
    });
  </script>
</Base>
