---
import '@picocss/pico/css/pico.classless.zinc.min.css';

interface Props {
  title: string;
  description?: string;
  /** Override og:type. Defaults to "website". */
  ogType?: string;
  /**
   * Override the canonical URL. May be a path ("/foo/") or absolute URL.
   * Resolved against Astro.site, so relative values are safe.
   * Defaults to the current page's normalized pathname.
   * Prefer setting this via Props rather than via <slot name="head" />
   * to avoid emitting duplicate canonical/og:url tags.
   */
  canonical?: string;
}

const {
  title,
  description = "Tyra is a readable, statically-typed, Ruby-flavored compiled language that compiles to native binaries via LLVM.",
  ogType = "website",
  canonical,
} = Astro.props;

// Normalize pathname: ensure trailing slash to match Astro's static directory output
// e.g. /compare/v  →  /compare/v/   (root "/" is already normalized)
const pathname = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : Astro.url.pathname + '/';

// Always resolve to absolute URLs. new URL() handles both relative paths and
// already-absolute values, so passing canonical="/foo/" or canonical="https://..."
// both produce correct absolute output.
const canonicalURL = new URL(canonical ?? pathname, Astro.site).href;
// OG image is a single shared asset. If per-page images are needed in the
// future, add imageWidth/imageHeight props at the same time to keep dimensions
// consistent with the actual file.
const ogImageURL   = new URL("/og.png", Astro.site).href;
const fullTitle    = `${title} · Tyra`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light dark" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type"        content={ogType} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:site_name"   content="Tyra" />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImageURL} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"   content="Tyra — a readable, statically-typed, Ruby-flavored compiled language" />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImageURL} />

  <!--
    Use <slot name="head" /> for page-specific extras that do NOT conflict
    with the tags above (e.g. <link rel="preload">, page-specific <script>).
    To override canonical, og:image, og:type, or og:title, use the Props
    (canonical / image / ogType / title) instead — slot injection would
    produce duplicate tags that crawlers handle inconsistently.
  -->
  <slot name="head" />

  <!-- Pre-paint theme init: avoids flash of wrong theme -->
  <script is:inline>
    (function () {
      var t = localStorage.getItem('tyra-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', t);
      document.documentElement.style.colorScheme = t;
    })();
  </script>

  <style is:global>
    /* ─── Tyra coral — full primary token set ─── */

    /* Light mode */
    [data-theme=light],
    :root:not([data-theme=dark]),
    :host:not([data-theme=dark]) {
      --pico-primary:                  #a5341c;
      --pico-primary-background:       #bf3d20;
      --pico-primary-border:           var(--pico-primary-background);
      --pico-primary-underline:        rgba(165, 52, 28, 0.5);
      --pico-primary-hover:            #7d2613;
      --pico-primary-hover-background: #a5341c;
      --pico-primary-hover-border:     var(--pico-primary-hover-background);
      --pico-primary-hover-underline:  var(--pico-primary-hover);
      --pico-primary-focus:            rgba(165, 52, 28, 0.375);
      --pico-primary-inverse:          #fff;
    }

    /* Dark mode — auto (system preference) */
    @media only screen and (prefers-color-scheme: dark) {
      :root:not([data-theme]) {
        --pico-primary:                  #f78166;
        --pico-primary-background:       #c74230;
        --pico-primary-border:           var(--pico-primary-background);
        --pico-primary-underline:        rgba(247, 129, 102, 0.5);
        --pico-primary-hover:            #f9a491;
        --pico-primary-hover-background: #d94e39;
        --pico-primary-hover-border:     var(--pico-primary-hover-background);
        --pico-primary-hover-underline:  var(--pico-primary-hover);
        --pico-primary-focus:            rgba(247, 129, 102, 0.375);
        --pico-primary-inverse:          #0d1117;
      }
    }

    /* Dark mode — forced via data-theme="dark" */
    [data-theme=dark] {
      --pico-primary:                  #f78166;
      --pico-primary-background:       #c74230;
      --pico-primary-border:           var(--pico-primary-background);
      --pico-primary-underline:        rgba(247, 129, 102, 0.5);
      --pico-primary-hover:            #f9a491;
      --pico-primary-hover-background: #d94e39;
      --pico-primary-hover-border:     var(--pico-primary-hover-background);
      --pico-primary-hover-underline:  var(--pico-primary-hover);
      --pico-primary-focus:            rgba(247, 129, 102, 0.375);
      --pico-primary-inverse:          #0d1117;
    }

    /* ─── Legacy variable aliases (other pages use these) ─── */
    :root {
      --bg:         var(--pico-background-color);
      --bg-secondary: var(--pico-card-sectioning-background-color);
      --border:     var(--pico-muted-border-color);
      --text:       var(--pico-color);
      --text-muted: var(--pico-muted-color);
      --accent:     var(--pico-primary);
      --code-bg:    var(--pico-code-background-color);
      --green:      #3fb950;
      --blue:       #58a6ff;
    }

    /* ─── Layout ─── */
    body {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    body > header {
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--pico-muted-border-color);
      background: var(--pico-background-color);
      padding: 0 1.5rem;
    }

    body > header > nav {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0;
      height: 56px;
    }

    body > header > nav > ul {
      margin: 0;
      padding: 0;
    }

    .nav-logo {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--pico-primary) !important;
      text-decoration: none !important;
    }

    #theme-toggle {
      background: none;
      border: none;
      padding: 0.25rem 0.4rem;
      cursor: pointer;
      font-size: 1rem;
      border-radius: var(--pico-border-radius);
      line-height: 1;
      color: var(--pico-muted-color);
      transition: color var(--pico-transition);
    }

    #theme-toggle:hover {
      color: var(--pico-color);
    }

    main {
      flex: 1;
      max-width: 1100px;
      width: 100%;
      margin: 0 auto;
      padding: 2.5rem 1.5rem;
    }

    body > footer {
      border-top: 1px solid var(--pico-muted-border-color);
      text-align: center;
      font-size: 0.85rem;
      color: var(--pico-muted-color);
      padding: 1.25rem 1.5rem;
    }

    body > footer a {
      color: var(--pico-muted-color);
    }

    /* ─── Button classes used in pages ─── */
    .btn {
      display: inline-block;
      padding: 0.6rem 1.2rem;
      border-radius: var(--pico-border-radius);
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.15s;
      text-decoration: none;
    }

    .btn:hover {
      opacity: 0.85;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--pico-primary);
      color: var(--pico-primary-inverse);
    }

    .btn-secondary {
      background: transparent;
      color: var(--pico-color);
      border: 1px solid var(--pico-muted-border-color);
    }

    /* ─── Typography overrides ─── */
    h1 { letter-spacing: -0.03em; }
    h2 { letter-spacing: -0.02em; }

    /* ─── Responsive ─── */
    @media (max-width: 640px) {
      h1 { font-size: 1.8rem; }
    }
  </style>
</head>
<body>
  <header>
    <nav>
      <ul>
        <li><a href="/" class="nav-logo">Tyra</a></li>
      </ul>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/playground">Playground</a></li>
        <li><a href="/compare/">Compare</a></li>
        <li><a href="/leaderboard">Leaderboard</a></li>
        <li><a href="https://dev.to/tyra-lang" target="_blank" rel="noopener">Blog ↗</a></li>
        <li>
          <button
            id="theme-toggle"
            type="button"
            aria-label="Switch to light mode"
          >🌙</button>
        </li>
      </ul>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    Apache-2.0 &middot; <a href="https://github.com/tyra-lang/tyra" target="_blank" rel="noopener">tyra-lang/tyra</a>
  </footer>

  <script>
    const btn = document.getElementById('theme-toggle') as HTMLButtonElement;

    function applyTheme(theme: string) {
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.style.colorScheme = theme;
      btn.textContent = theme === 'dark' ? '☀️' : '🌙';
      btn.setAttribute('aria-label', theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
    }

    // Sync button label with current theme (set by pre-paint script)
    applyTheme(document.documentElement.getAttribute('data-theme') ?? 'light');

    btn.addEventListener('click', () => {
      const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      applyTheme(next);
      localStorage.setItem('tyra-theme', next);
    });
  </script>
</body>
</html>
